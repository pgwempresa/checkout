# ============================================================
# CHECKOUT PAY — VARIAVEIS DE AMBIENTE
# Copie para .env e preencha os valores
# ============================================================

# ----- Persistência Redis (Vercel KV / Upstash) -------------
# Sem isso, dados são perdidos a cada restart (serverless)
# Vercel KV: Settings → Storage → Create KV → copie as vars
# Upstash:   upstash.com → crie Redis → REST API
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Alternativa Upstash direta:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ----- Webhook para sua loja --------------------------------
# URL que recebe POST quando pagamento é confirmado/recusado
# CHECKOUT_STORE_WEBHOOK_URL=https://minhaloja.com.br/api/webhook/pix

# Segredo para validar assinatura dos webhooks recebidos (HMAC-SHA256)
# Quando definido, a adquirente deve enviar o header x-webhook-signature
# Se não definir, webhooks são aceitos sem verificação (menos seguro)
# WEBHOOK_SECRET=

# ----- Admin ------------------------------------------------
# Senha para acessar o painel admin (obrigatorio)
ADMIN_PASSWORD=troque-essa-senha

# Segredo para assinar os tokens admin (recomendado em producao)
# Se nao definir, usa ADMIN_PASSWORD como segredo
ADMIN_SECRET=

# ----- Checkout / Deploy ------------------------------------
# URL publica onde esse checkout esta rodando
CHECKOUT_PUBLIC_URL=https://checkout.seudominio.com.br

# Nome da sua loja (aparece no painel)
CHECKOUT_STORE_NAME=Minha Loja

# URL da sua loja HTML
CHECKOUT_STORE_URL=https://minhaloja.com.br

# Adquirente padrao: velana | bestfy
CHECKOUT_ACTIVE_PROVIDER=velana

# Modo de persistencia do runtime: memory | file | readonly
# memory: dados perdidos ao reiniciar (ok para desenvolvimento)
# file: salva em /tmp/checkout-pay-state.json (ok para VPS)
# readonly: sem persistencia (Vercel/serverless — troque provider via env)
CHECKOUT_STORAGE_MODE=memory

# Caminho do arquivo de estado (apenas se CHECKOUT_STORAGE_MODE=file)
# CHECKOUT_STATE_FILE=/tmp/checkout-pay-state.json

# URL de postback/webhook apos pagamento confirmado
# CHECKOUT_POSTBACK_URL=https://minhaloja.com.br/api/webhook/pagamento

# ----- Adquirente: Velana -----------------------------------
VELANA_SECRET_KEY=

# ----- Adquirente: Bestfy -----------------------------------
BESTFY_SECRET_KEY=
# BESTFY_API_KEY=

# ----- Adquirente: TexasPay (FastSoft Brasil) ---------------
TEXASPAY_SECRET_KEY=
TEXASPAY_PUBLIC_KEY=

# ----- Notificações por email (Resend) ----------------------
# Crie uma conta em resend.com e gere uma API key
RESEND_API_KEY=
# Endereço de envio (precisa ser de um domínio verificado no Resend)
NOTIFY_EMAIL_FROM=pagamentos@checkoutpay.com.br
# Destinatário(s) das notificações — separe com vírgula para múltiplos
NOTIFY_EMAIL_TO=
